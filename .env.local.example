# Google Sheets Spreadsheet ID
# Found in the URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Google Service Account credentials (from the downloaded JSON key file)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# The private key from the JSON key file.
# Copy the value of "private_key" exactly, including the BEGIN/END markers.
# On Vercel, paste it as-is. Locally in .env.local, wrap the entire value in double quotes.
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
